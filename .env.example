# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Get from platform.openai.com/api-keys
# Used for: AI report analysis, multilingual chat intake, priority routing
# Model: gpt-4o-mini (cost-efficient; upgrade to gpt-4o for higher accuracy)
# If not set: smart rule-based fallback activates automatically
OPENAI_API_KEY=sk-...

# ─── Admin Auth ──────────────────────────────────────────────────────────────
# Simple password for admin login (change for production)
ADMIN_EMAIL=admin@cityfix.ai
ADMIN_PASSWORD=cityfix-admin-2024

# ─── App Config ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Demo Mode ───────────────────────────────────────────────────────────────
# Set to "true" to use built-in demo data — works with no Supabase or OpenAI key
# All features (chat, routing, scoring, map, analytics) work in demo mode
NEXT_PUBLIC_DEMO_MODE=false
